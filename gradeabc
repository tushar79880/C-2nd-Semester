#include <iostream>
using namespace std;
int main ()
{
    int Marks;
    cout<<"Enter the Marks: ";
    cin>>Marks;
    if(Marks>=90)
    cout << "Grade: A"<< endl;
    else if(Marks>=75)
    cout<<"Grade: B"<<endl;
    else if(Marks>=40)
    cout<<"Grade: C"<<endl;
    else
    cout<<"Result: Fail"<<endl;
    return 0;
}
